[
  {
    "name": "search",
    "description": "根据关键词搜索A股股票代码，返回股票代码、名称、市场信息。当只知道股票名称（如"茅台"、"比亚迪"）而不知道代码时，必须先调用此工具获取代码，再进行后续分析。",
    "parameters": {
      "type": "object",
      "properties": {
        "keyword": {
          "type": "string",
          "description": "搜索关键词，可以是股票名称或代码"
        }
      },
      "required": ["keyword"]
    }
  },
  {
    "name": "kline",
    "description": "获取股票K线数据和技术指标（MA/MACD/RSI/KDJ等），用于技术面分析。需先用 search 工具获取股票代码（6位数字）。",
    "parameters": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "股票代码（6位数字）"
        },
        "period": {
          "type": "string",
          "enum": ["daily", "weekly", "monthly"],
          "default": "daily",
          "description": "K线周期"
        },
        "limit": {
          "type": "integer",
          "default": 60,
          "description": "返回数据条数"
        }
      },
      "required": ["code"]
    }
  },
  {
    "name": "fundamental",
    "description": "获取股票基本面数据，包括PE/PB/ROE/市值/财务指标等，用于估值分析和基本面研究。需先用 search 工具获取股票代码（6位数字）。",
    "parameters": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "股票代码（6位数字）"
        }
      },
      "required": ["code"]
    }
  },
  {
    "name": "sectors",
    "description": "获取A股所有行业板块列表，包括板块代码、涨跌幅、龙头股等",
    "parameters": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "concepts",
    "description": "获取A股所有概念板块列表，用于追踪热点题材",
    "parameters": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "default": "concepts",
          "description": "板块类型"
        }
      }
    }
  },
  {
    "name": "sector-stocks",
    "description": "获取指定板块内的成分股列表",
    "parameters": {
      "type": "object",
      "properties": {
        "sectorCode": {
          "type": "string",
          "description": "板块代码"
        },
        "limit": {
          "type": "integer",
          "default": 20,
          "description": "返回股票数量"
        }
      },
      "required": ["sectorCode"]
    }
  },
  {
    "name": "news",
    "description": "获取指定股票的最新新闻和公告，辅助判断近期催化剂或风险事件。需先用 search 工具获取股票代码（6位数字）。",
    "parameters": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "股票代码（6位数字）"
        },
        "limit": {
          "type": "integer",
          "default": 10,
          "description": "返回新闻数量"
        }
      },
      "required": ["code"]
    }
  }
]
